# Memory Mate — environment template. Copy to .env and fill in your values.
#   cp .env.example .env
#
# Find these in the Supabase dashboard: Project Settings -> API.
# Both are safe to ship in the client (the anon/publishable key is protected by
# Row Level Security). Do NOT add the service_role key or database password here.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
